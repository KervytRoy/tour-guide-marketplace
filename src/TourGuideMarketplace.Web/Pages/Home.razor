@page "/"
@layout PublicHomeLayout
@attribute [AllowAnonymous]
@inject GuidesApiClient GuidesApi
@inject NavigationManager Navigation

<div class="market-home">
    <header class="market-home-header">
        <a class="market-brand" href="/" aria-label="Tour Guide Marketplace inicio">
            <span class="market-brand-mark">
                <MudIcon Icon="@Icons.Material.Filled.Explore" />
            </span>
            <span>Tour Guide Marketplace</span>
        </a>

        <nav class="market-home-tabs" aria-label="Secciones principales">
            @foreach (var tab in _tabs)
            {
                <button type="button" class="@GetTabClass(tab.Section)" @onclick="@(() => SelectSection(tab.Section))">
                    <MudIcon Icon="@tab.Icon" />
                    <span>@GetTabLabel(tab)</span>
                </button>
            }
        </nav>

        <div class="market-home-actions">
            <MudButton Href="/register?role=Guide" Variant="Variant.Text" Color="Color.Inherit" Class="market-guide-link">
                @T("Conviertete en Guia", "Become a Guide")
            </MudButton>

            <div class="market-language-picker">
                <MudMenu Icon="@Icons.Material.Filled.Language" Color="Color.Inherit" Dense="true" Class="market-round-menu" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                    <MudMenuItem OnClick="@SetLanguageEs">Espanol</MudMenuItem>
                    <MudMenuItem OnClick="@SetLanguageEn">English</MudMenuItem>
                </MudMenu>
                <span>@_language</span>
            </div>

            <MudMenu Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Dense="true" Class="market-round-menu" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                <MudMenuItem Href="/help" Icon="@Icons.Material.Filled.HelpOutline">@T("Centro de ayuda", "Help center")</MudMenuItem>
                <MudMenuItem Href="/register?role=Guide" Icon="@Icons.Material.Filled.Badge">@T("Conviertete en Guia", "Become a Guide")</MudMenuItem>
                <MudMenuItem Href="/login" Icon="@Icons.Material.Filled.Login">@T("Iniciar sesion/registrarse", "Log in/sign up")</MudMenuItem>
            </MudMenu>
        </div>
    </header>

    <main>
        <section class="market-search-band" aria-label="Busqueda principal">
            <div class="market-search-card">
                <label class="market-search-field">
                    <span>@GetPrimaryLabel()</span>
                    <input @bind="_primarySearch" placeholder="@GetPrimaryPlaceholder()" />
                </label>

                <label class="market-search-field">
                    <span>@GetSecondaryLabel()</span>
                    <input @bind="_secondarySearch" placeholder="@GetSecondaryPlaceholder()" />
                </label>

                <label class="market-search-field">
                    <span>@GetTertiaryLabel()</span>
                    <input @bind="_tertiarySearch" placeholder="@GetTertiaryPlaceholder()" />
                </label>

                <MudIconButton Icon="@Icons.Material.Filled.Search" Color="Color.Inherit" Class="market-search-button" OnClick="RunSearch" aria-label="@GetSearchLabel()" />
            </div>
        </section>

        <section class="market-home-content">
            @switch (_activeSection)
            {
                case HomeSection.Guides:
                    @RenderGuidesSection()
                    break;
                case HomeSection.TravelFriends:
                    @RenderTravelFriendsSection()
                    break;
                case HomeSection.Places:
                    @RenderPlacesSection()
                    break;
            }
        </section>
    </main>
</div>

@code {
    private enum HomeSection
    {
        Guides,
        TravelFriends,
        Places
    }

    private HomeSection _activeSection = HomeSection.Guides;
    private string _language = "ES";
    private string? _primarySearch;
    private string? _secondarySearch;
    private string? _tertiarySearch;
    private string _activePlaceFilter = "Todos";
    private bool _isBusy;
    private IReadOnlyCollection<GuideProfileResponse> _guides = [];
    private IReadOnlyCollection<string> _errors = [];

    private readonly IReadOnlyList<HomeTab> _tabs =
    [
        new(HomeSection.Guides, "GUIAS", "GUIDES", Icons.Material.Filled.TravelExplore),
        new(HomeSection.TravelFriends, "AMIGOS DE VIAJE", "TRAVEL FRIENDS", Icons.Material.Filled.Groups),
        new(HomeSection.Places, "LUGARES", "PLACES", Icons.Material.Filled.LocationOn)
    ];

    private readonly IReadOnlyList<TravelFriendPreview> _travelFriends =
    [
        new("Ana y Diego", "Cusco, Peru", "Cultura y fotografia", "Culture and photography", "Junio 2026", "June 2026", ["Espanol", "Flexible"], ["Spanish", "Flexible"]),
        new("Marco", "Cartagena, Colombia", "Gastronomia local", "Local food", "Julio 2026", "July 2026", ["Ingles", "Grupo pequeno"], ["English", "Small group"]),
        new("Lucia", "Oaxaca, Mexico", "Mercados y caminatas", "Markets and walks", "Agosto 2026", "August 2026", ["Espanol", "Presupuesto medio"], ["Spanish", "Mid budget"])
    ];

    private readonly IReadOnlyList<string> _placeFilters = ["Todos", "Playa", "Cultura", "Aventura", "Gastronomia", "Naturaleza"];

    private readonly IReadOnlyList<DestinationRecommendation> _destinations =
    [
        new("Cusco", "Peru", "Cultura", "Medio", "Mayo a septiembre", "May to September", "https://images.unsplash.com/photo-1526392060635-9d6019884377?auto=format&fit=crop&w=900&q=80"),
        new("Cartagena", "Colombia", "Playa", "Medio", "Diciembre a abril", "December to April", "https://images.unsplash.com/photo-1666977461267-c0e924696510?auto=format&fit=crop&w=900&q=80"),
        new("Oaxaca", "Mexico", "Gastronomia", "Accesible", "Octubre a marzo", "October to March", "https://images.unsplash.com/photo-1598057049437-d905bf389631?auto=format&fit=crop&w=900&q=80"),
        new("Bariloche", "Argentina", "Naturaleza", "Medio alto", "Noviembre a marzo", "November to March", "https://upload.wikimedia.org/wikipedia/commons/thumb/e/ee/Mountains_and_Lake_in_Bariloche_%28Unsplash%29.jpg/960px-Mountains_and_Lake_in_Bariloche_%28Unsplash%29.jpg"),
        new("San Pedro de Atacama", "Chile", "Aventura", "Medio alto", "Marzo a mayo", "March to May", "https://upload.wikimedia.org/wikipedia/commons/thumb/f/f5/Abandoned_bus_in_San_Pedro_de_Atacama_%28Unsplash%29.jpg/960px-Abandoned_bus_in_San_Pedro_de_Atacama_%28Unsplash%29.jpg")
    ];

    private IEnumerable<DestinationRecommendation> FilteredDestinations =>
        _activePlaceFilter == "Todos"
            ? _destinations
            : _destinations.Where(destination => destination.Category == _activePlaceFilter);

    protected override Task OnInitializedAsync()
    {
        return LoadVerifiedGuidesAsync();
    }

    private RenderFragment RenderGuidesSection() => @<div>
        <div class="market-section-heading">
            <div>
                <MudText Typo="Typo.h4">@T("Guias verificados", "Verified guides")</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    @T("Encuentra expertos locales listos para ayudarte a descubrir tu proximo destino.", "Find local experts ready to help you discover your next destination.")
                </MudText>
            </div>
            <MudButton Href="/register?role=Guide" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Badge">
                @T("Conviertete en Guia", "Become a Guide")
            </MudButton>
        </div>

        @if (_isBusy)
        {
            <div class="app-loading">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (_errors.Count > 0)
        {
            <MudPaper Class="state-panel" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.CloudOff" Color="Color.Secondary" Size="Size.Large" />
                <MudText Typo="Typo.h6">@T("No pudimos cargar los guias", "We could not load the guides")</MudText>
                <MudText Color="Color.Secondary">@GetGuideErrorText()</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadVerifiedGuidesAsync" StartIcon="@Icons.Material.Filled.Refresh">
                    @T("Reintentar", "Retry")
                </MudButton>
            </MudPaper>
        }
        else if (_guides.Count == 0)
        {
            <MudPaper Class="state-panel" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.TravelExplore" Color="Color.Secondary" Size="Size.Large" />
                <MudText Typo="Typo.h6">@T("Aun no hay guias verificados", "There are no verified guides yet")</MudText>
                <MudText Color="Color.Secondary">@T("Vuelve pronto para explorar nuevos perfiles aprobados.", "Come back soon to explore newly approved profiles.")</MudText>
            </MudPaper>
        }
        else
        {
            <div class="home-guide-grid">
                @foreach (var guide in _guides)
                {
                    <a class="home-guide-card-link" href="@GetGuideProfileUrl(guide.Id)" aria-label="@($"Ver perfil de {guide.GuideName}")">
                        <MudPaper Class="home-guide-card" Elevation="0">
                            <div class="home-guide-photo">
                                @if (!string.IsNullOrWhiteSpace(guide.PhotoUrl))
                                {
                                    <img src="@guide.PhotoUrl" alt="@($"Foto de {guide.GuideName}")" class="home-guide-image" />
                                }
                                else
                                {
                                    <MudAvatar Size="Size.Large" Color="Color.Primary">@GetInitials(guide.GuideName)</MudAvatar>
                                }
                            </div>

                            <div class="home-guide-content">
                                <MudText Typo="Typo.subtitle1" Class="home-guide-name">@guide.GuideName</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@guide.City, @guide.Country</MudText>

                                <div class="home-guide-tags">
                                    @foreach (var specialty in guide.Specialties.Take(2))
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@specialty</MudChip>
                                    }
                                </div>
                            </div>
                        </MudPaper>
                    </a>
                }
            </div>
        }
    </div>;

    private RenderFragment RenderTravelFriendsSection() => @<div>
        <div class="market-section-heading">
            <div>
                <MudText Typo="Typo.h4">@T("Amigos de viaje", "Travel friends")</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    @T("Coincide con personas que quieren explorar rutas similares.", "Match with people who want to explore similar routes.")
                </MudText>
            </div>
            <MudChip T="string" Color="Color.Secondary" Variant="Variant.Filled">@T("Proxima instancia", "Future release")</MudChip>
        </div>

        <div class="travel-friend-grid">
            @foreach (var friend in _travelFriends)
            {
                <MudPaper Class="travel-friend-card" Elevation="0">
                    <div class="travel-friend-top">
                        <MudAvatar Color="Color.Secondary" Size="Size.Large">@GetInitials(friend.Name)</MudAvatar>
                        <div>
                            <MudText Typo="Typo.h6">@friend.Name</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@friend.Destination</MudText>
                        </div>
                    </div>
                    <MudText Typo="Typo.body2" Class="travel-friend-style">@GetTravelFriendStyle(friend)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@GetTravelFriendWindow(friend)</MudText>
                    <div class="home-guide-tags">
                        @foreach (var tag in GetTravelFriendTags(friend))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@tag</MudChip>
                        }
                    </div>
                </MudPaper>
            }
        </div>
    </div>;

    private RenderFragment RenderPlacesSection() => @<div>
        <div class="market-section-heading">
            <div>
                <MudText Typo="Typo.h4">@T("Lugares recomendados", "Recommended places")</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    @T("Explora destinos por estilo de viaje cuando aun no tienes un plan cerrado.", "Explore destinations by travel style when you do not have a fixed plan yet.")
                </MudText>
            </div>
        </div>

        <div class="place-filter-row" aria-label="Filtros de lugares">
            @foreach (var filter in _placeFilters)
            {
                <button type="button" class="@GetPlaceFilterClass(filter)" @onclick="@(() => _activePlaceFilter = filter)">
                    @GetPlaceFilterLabel(filter)
                </button>
            }
        </div>

        <div class="destination-grid">
            @foreach (var destination in FilteredDestinations)
            {
                <MudPaper Class="destination-card" Elevation="0">
                    <div class="destination-image-shell">
                        <img src="@destination.ImageUrl" alt="@destination.Name" class="destination-image" onerror="this.parentElement.classList.add('is-missing')" />
                    </div>
                    <div class="destination-card-content">
                        <MudText Typo="Typo.h6">@destination.Name</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@destination.Country</MudText>
                        <div class="destination-meta">
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@GetCategoryLabel(destination.Category)</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@GetBudgetLabel(destination.Budget)</MudChip>
                        </div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@GetSeasonLabel(destination)</MudText>
                    </div>
                </MudPaper>
            }
        </div>
    </div>;

    private async Task LoadVerifiedGuidesAsync()
    {
        _isBusy = true;
        _errors = [];
        var result = await GuidesApi.SearchAsync(new GuideSearchRequest(
            City: null,
            Country: null,
            Specialty: null,
            Language: null,
            MaxHourlyRate: null,
            MinRating: null,
            AvailableNow: null,
            PageNumber: 1,
            PageSize: 24));
        _isBusy = false;

        if (!result.Succeeded)
        {
            _errors = result.Errors;
            return;
        }

        _guides = result.Value?.Items ?? [];
    }

    private void SelectSection(HomeSection section)
    {
        _activeSection = section;
        _primarySearch = null;
        _secondarySearch = null;
        _tertiarySearch = null;
    }

    private void RunSearch()
    {
        if (_activeSection == HomeSection.Guides)
        {
            Navigation.NavigateTo("/guides");
        }
    }

    private void SetLanguageEs()
    {
        _language = "ES";
    }

    private void SetLanguageEn()
    {
        _language = "EN";
    }

    private bool IsEnglish => _language == "EN";

    private string T(string spanish, string english)
    {
        return IsEnglish ? english : spanish;
    }

    private string GetTabLabel(HomeTab tab)
    {
        return T(tab.SpanishLabel, tab.EnglishLabel);
    }

    private string GetTabClass(HomeSection section)
    {
        return section == _activeSection ? "market-home-tab is-active" : "market-home-tab";
    }

    private string GetPlaceFilterClass(string filter)
    {
        return filter == _activePlaceFilter ? "place-filter is-active" : "place-filter";
    }

    private string GetPrimaryLabel()
    {
        return _activeSection switch
        {
            HomeSection.Guides => T("Donde", "Where"),
            HomeSection.TravelFriends => T("Destino", "Destination"),
            _ => T("Lugar", "Place")
        };
    }

    private string GetPrimaryPlaceholder()
    {
        return _activeSection switch
        {
            HomeSection.Guides => T("Explora destinos", "Explore destinations"),
            HomeSection.TravelFriends => T("A donde quieres viajar?", "Where do you want to travel?"),
            _ => T("Ciudad, pais o estilo", "City, country or style")
        };
    }

    private string GetSecondaryLabel()
    {
        return _activeSection switch
        {
            HomeSection.Guides => T("Fechas", "Dates"),
            HomeSection.TravelFriends => T("Fechas", "Dates"),
            _ => T("Presupuesto", "Budget")
        };
    }

    private string GetSecondaryPlaceholder()
    {
        return _activeSection switch
        {
            HomeSection.Guides => T("Agrega fechas", "Add dates"),
            HomeSection.TravelFriends => T("Ventana flexible", "Flexible window"),
            _ => T("Bajo, medio o alto", "Low, medium or high")
        };
    }

    private string GetTertiaryLabel()
    {
        return _activeSection switch
        {
            HomeSection.Guides => T("Quien", "Who"),
            HomeSection.TravelFriends => T("Afinidad", "Fit"),
            _ => T("Filtro", "Filter")
        };
    }

    private string GetTertiaryPlaceholder()
    {
        return _activeSection switch
        {
            HomeSection.Guides => T("Cuantos?", "How many?"),
            HomeSection.TravelFriends => T("Intereses o ritmo", "Interests or pace"),
            _ => T("Playa, cultura, aventura", "Beach, culture, adventure")
        };
    }

    private string GetSearchLabel()
    {
        return _activeSection switch
        {
            HomeSection.Guides => T("Buscar guias", "Search guides"),
            HomeSection.TravelFriends => T("Buscar amigos de viaje", "Search travel friends"),
            _ => T("Buscar lugares", "Search places")
        };
    }

    private string GetTravelFriendStyle(TravelFriendPreview friend)
    {
        return T(friend.StyleEs, friend.StyleEn);
    }

    private string GetGuideErrorText()
    {
        var errorText = string.Join(" ", _errors);

        return IsEnglish && errorText == "No se pudo conectar con la API."
            ? "Could not connect to the API."
            : errorText;
    }

    private static string GetGuideProfileUrl(Guid guideId)
    {
        return $"/guides/{guideId}";
    }

    private string GetTravelFriendWindow(TravelFriendPreview friend)
    {
        return T(friend.TravelWindowEs, friend.TravelWindowEn);
    }

    private IReadOnlyList<string> GetTravelFriendTags(TravelFriendPreview friend)
    {
        return IsEnglish ? friend.TagsEn : friend.TagsEs;
    }

    private string GetPlaceFilterLabel(string filter)
    {
        return filter switch
        {
            "Todos" => T("Todos", "All"),
            "Playa" => T("Playa", "Beach"),
            "Cultura" => T("Cultura", "Culture"),
            "Aventura" => T("Aventura", "Adventure"),
            "Gastronomia" => T("Gastronomia", "Food"),
            "Naturaleza" => T("Naturaleza", "Nature"),
            _ => filter
        };
    }

    private string GetCategoryLabel(string category)
    {
        return category switch
        {
            "Playa" => T("Playa", "Beach"),
            "Cultura" => T("Cultura", "Culture"),
            "Aventura" => T("Aventura", "Adventure"),
            "Gastronomia" => T("Gastronomia", "Food"),
            "Naturaleza" => T("Naturaleza", "Nature"),
            _ => category
        };
    }

    private string GetBudgetLabel(string budget)
    {
        return budget switch
        {
            "Medio" => T("Medio", "Medium"),
            "Accesible" => T("Accesible", "Accessible"),
            "Medio alto" => T("Medio alto", "Upper medium"),
            _ => budget
        };
    }

    private string GetSeasonLabel(DestinationRecommendation destination)
    {
        return T(destination.SeasonEs, destination.SeasonEn);
    }

    private static string GetInitials(string value)
    {
        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length == 0
            ? "GM"
            : string.Concat(parts.Take(2).Select(part => part[0])).ToUpperInvariant();
    }

    private sealed record HomeTab(HomeSection Section, string SpanishLabel, string EnglishLabel, string Icon);

    private sealed record TravelFriendPreview(
        string Name,
        string Destination,
        string StyleEs,
        string StyleEn,
        string TravelWindowEs,
        string TravelWindowEn,
        IReadOnlyList<string> TagsEs,
        IReadOnlyList<string> TagsEn);

    private sealed record DestinationRecommendation(
        string Name,
        string Country,
        string Category,
        string Budget,
        string SeasonEs,
        string SeasonEn,
        string ImageUrl);
}
