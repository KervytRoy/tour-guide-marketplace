@page "/not-found"

<MudPaper Class="state-panel" Elevation="0">
    <MudIcon Icon="@Icons.Material.Filled.ExploreOff" Color="Color.Secondary" Size="Size.Large" />
    <MudText Typo="Typo.h5">Pagina no encontrada</MudText>
    <MudText Color="Color.Secondary">La ruta que intentaste abrir no existe en este sitio.</MudText>
    <MudButton Href="/dashboard" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.SpaceDashboard">
        Ir al dashboard
    </MudButton>
</MudPaper>
