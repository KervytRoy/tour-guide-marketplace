@page "/guides/search"
@layout PublicHomeLayout
@attribute [AllowAnonymous]
@using System.Globalization
@inject GuidesApiClient GuidesApi
@inject IStringLocalizer<SharedResource> L

<div class="market-home">
    <PublicMarketHeader />

    <main class="market-home-content public-guide-results-page">
        <section class="public-results-search">
            <PublicGuideSearchBar Destination="@Destination"
                                  StartDate="@StartDate"
                                  EndDate="@EndDate"
                                  Adults="@Adults"
                                  Children="@Children"
                                  Infants="@Infants" />
        </section>

        <section class="public-results-heading">
            <div>
                <MudText Typo="Typo.h4">@GetResultsTitle()</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">@L["GuideSearchResultsSubtitle"]</MudText>
            </div>

            @if (HasTripContext)
            {
                <div class="guide-search-context">
                    @if (!string.IsNullOrWhiteSpace(Destination))
                    {
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.LocationOn">
                            @Destination
                        </MudChip>
                    }
                    @if (!string.IsNullOrWhiteSpace(GetDateRangeText()))
                    {
                        <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.DateRange">
                            @GetDateRangeText()
                        </MudChip>
                    }
                    @if (!string.IsNullOrWhiteSpace(GetTravelersText()))
                    {
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Groups">
                            @GetTravelersText()
                        </MudChip>
                    }
                </div>
            }
        </section>

        @if (_isBusy)
        {
            <div class="app-loading">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (_errors.Count > 0)
        {
            <MudPaper Class="state-panel" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.CloudOff" Color="Color.Secondary" Size="Size.Large" />
                <MudText Typo="Typo.h6">@L["GuideSearchLoadFailed"]</MudText>
                <MudText Color="Color.Secondary">@string.Join(" ", _errors)</MudText>
                <MudButton Href="/" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack">
                    @L["BackToHome"]
                </MudButton>
            </MudPaper>
        }
        else if (_guides.Count == 0)
        {
            <MudPaper Class="state-panel" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.TravelExplore" Color="Color.Secondary" Size="Size.Large" />
                <MudText Typo="Typo.h5">@GetNoResultsTitle()</MudText>
                <MudText Color="Color.Secondary">@L["GuideSearchNoResultsDescription"]</MudText>
                <MudButton Href="/" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack">
                    @L["BackToHome"]
                </MudButton>
            </MudPaper>
        }
        else
        {
            <div class="public-results-grid">
                @foreach (var guide in _guides)
                {
                    <a class="home-guide-card-link" href="@GetGuideProfileUrl(guide.Id)" aria-label="@L["ViewGuideProfileAria", guide.GuideName]">
                        <MudPaper Class="home-guide-card" Elevation="0">
                            <div class="home-guide-photo">
                                @if (!string.IsNullOrWhiteSpace(guide.PhotoUrl))
                                {
                                    <img src="@guide.PhotoUrl" alt="@L["GuidePhotoAlt", guide.GuideName]" class="home-guide-image" />
                                }
                                else
                                {
                                    <MudAvatar Size="Size.Large" Color="Color.Primary">@GetInitials(guide.GuideName)</MudAvatar>
                                }
                            </div>

                            <div class="home-guide-content">
                                <MudText Typo="Typo.subtitle1" Class="home-guide-name">@guide.GuideName</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@guide.City, @guide.Country</MudText>

                                <div class="guide-meta">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@L["HourlyRateDisplay", guide.Currency, guide.HourlyRate]</MudChip>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@L["RatingDisplay", guide.AverageRating]</MudChip>
                                </div>

                                <MudText Typo="Typo.caption" Color="Color.Secondary">@guide.Specialties</MudText>
                            </div>
                        </MudPaper>
                    </a>
                }
            </div>
        }
    </main>
</div>

@code {
    private bool _isBusy;
    private IReadOnlyCollection<GuideProfileResponse> _guides = [];
    private IReadOnlyCollection<string> _errors = [];

    [Parameter, SupplyParameterFromQuery(Name = "destination")]
    public string? Destination { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "startDate")]
    public string? StartDate { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "endDate")]
    public string? EndDate { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "adults")]
    public int? Adults { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "children")]
    public int? Children { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "infants")]
    public int? Infants { get; set; }

    private bool HasTripContext =>
        !string.IsNullOrWhiteSpace(Destination)
        || !string.IsNullOrWhiteSpace(GetDateRangeText())
        || !string.IsNullOrWhiteSpace(GetTravelersText());

    protected override Task OnParametersSetAsync()
    {
        return SearchAsync();
    }

    private async Task SearchAsync()
    {
        _isBusy = true;
        _errors = [];
        _guides = [];

        var location = ParseDestination(Destination);
        var result = await SearchGuidesAsync(location.City, location.Country);

        if (result.Succeeded && result.Value?.Items.Count == 0 && location.Country is null && !string.IsNullOrWhiteSpace(location.City))
        {
            result = await SearchGuidesAsync(city: null, country: location.City);
        }

        _isBusy = false;

        if (!result.Succeeded)
        {
            _errors = result.Errors;
            return;
        }

        _guides = result.Value?.Items ?? [];
    }

    private Task<ApiResult<PagedResult<GuideProfileResponse>>> SearchGuidesAsync(string? city, string? country)
    {
        return GuidesApi.SearchAsync(new GuideSearchRequest(
            City: city,
            Country: country,
            Specialty: null,
            Language: null,
            MaxHourlyRate: null,
            MinRating: null,
            AvailableNow: null,
            PageNumber: 1,
            PageSize: 48));
    }

    private string GetResultsTitle()
    {
        return string.IsNullOrWhiteSpace(Destination)
            ? L["GuideSearchResultsTitle"].Value
            : L["GuideSearchResultsForDestination", Destination.Trim()].Value;
    }

    private string GetNoResultsTitle()
    {
        return string.IsNullOrWhiteSpace(Destination)
            ? L["GuideSearchNoResultsTitleGeneric"].Value
            : L["GuideSearchNoResultsTitle", Destination.Trim()].Value;
    }

    private string GetGuideProfileUrl(Guid guideId)
    {
        var parameters = new List<string>();
        Add(parameters, "destination", Destination);
        Add(parameters, "startDate", NormalizeDate(StartDate));
        Add(parameters, "endDate", NormalizeDate(EndDate));
        Add(parameters, "adults", Adults is > 0 ? Adults.Value.ToString() : null);
        Add(parameters, "children", Children is > 0 ? Children.Value.ToString() : null);
        Add(parameters, "infants", Infants is > 0 ? Infants.Value.ToString() : null);

        return parameters.Count == 0
            ? $"/guides/{guideId}"
            : $"/guides/{guideId}?{string.Join("&", parameters)}";
    }

    private string GetDateRangeText()
    {
        var startDate = FormatDate(StartDate);
        var endDate = FormatDate(EndDate);

        if (startDate is null && endDate is null)
        {
            return string.Empty;
        }

        if (startDate is null)
        {
            return endDate!;
        }

        if (endDate is null)
        {
            return startDate;
        }

        return L["GuideSearchDateRangeDisplay", startDate, endDate].Value;
    }

    private string GetTravelersText()
    {
        var travelers = Math.Max(Adults ?? 0, 0) + Math.Max(Children ?? 0, 0);
        var infants = Math.Max(Infants ?? 0, 0);
        var parts = new List<string>();

        if (travelers == 1)
        {
            parts.Add(L["GuideSearchOneTraveler"].Value);
        }
        else if (travelers > 1)
        {
            parts.Add(L["GuideSearchManyTravelers", travelers].Value);
        }

        if (infants == 1)
        {
            parts.Add(L["GuideSearchOneInfant"].Value);
        }
        else if (infants > 1)
        {
            parts.Add(L["GuideSearchManyInfants", infants].Value);
        }

        return string.Join(" - ", parts);
    }

    private static SearchLocation ParseDestination(string? destination)
    {
        if (string.IsNullOrWhiteSpace(destination))
        {
            return new SearchLocation(null, null);
        }

        var parts = destination
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(part => !string.IsNullOrWhiteSpace(part))
            .ToArray();

        return parts.Length switch
        {
            0 => new SearchLocation(null, null),
            1 => new SearchLocation(parts[0], null),
            _ => new SearchLocation(parts[0], parts[^1])
        };
    }

    private static string? NormalizeDate(string? value)
    {
        return DateTime.TryParse(value, out var date)
            ? date.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)
            : null;
    }

    private static string? FormatDate(string? value)
    {
        return DateTime.TryParse(value, out var date)
            ? date.ToString("dd MMM yyyy", CultureInfo.CurrentUICulture)
            : null;
    }

    private static string GetInitials(string value)
    {
        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length == 0
            ? "GM"
            : string.Concat(parts.Take(2).Select(part => part[0])).ToUpperInvariant();
    }

    private static void Add(List<string> parameters, string name, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            parameters.Add($"{Uri.EscapeDataString(name)}={Uri.EscapeDataString(value.Trim())}");
        }
    }

    private sealed record SearchLocation(string? City, string? Country);
}
