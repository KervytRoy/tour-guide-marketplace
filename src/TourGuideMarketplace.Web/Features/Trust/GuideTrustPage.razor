@page "/guide/trust"
@attribute [Authorize(Roles = AppRoles.Guide)]
@inject TrustApiClient TrustApi
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResource> L

<MudStack Spacing="3">
    <div class="page-heading">
        <div>
            <MudText Typo="Typo.h4">@L["IdentityValidation"]</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                @L["IdentityValidationSubtitle"]
            </MudText>
        </div>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="@_isLoading" OnClick="LoadStatusAsync" StartIcon="@Icons.Material.Filled.Refresh">
            @L["Refresh"]
        </MudButton>
    </div>

    @if (_isLoading)
    {
        <div class="app-loading">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else if (_status is null)
    {
        <MudPaper Class="state-panel" Elevation="0">
            <MudIcon Icon="@Icons.Material.Filled.CloudOff" Color="Color.Warning" Size="Size.Large" />
            <MudText Typo="Typo.h6">@L["StatusLoadFailed"]</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadStatusAsync">
                @L["Retry"]
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="trust-summary-panel" Elevation="0">
            <div>
                <MudText Typo="Typo.overline">@L["Status"]</MudText>
                <MudText Typo="Typo.h5">@GetStatusLabel(_status.Status)</MudText>
                @if (!string.IsNullOrWhiteSpace(_status.InReviewReason))
                {
                    <MudText Color="Color.Secondary">@_status.InReviewReason</MudText>
                }
                @if (!string.IsNullOrWhiteSpace(_status.SuspendedReason))
                {
                    <MudText Color="Color.Error">@_status.SuspendedReason</MudText>
                }
            </div>
            <div class="trust-progress">
                <MudText Typo="Typo.caption" Color="Color.Secondary">@L["RequirementsProgress", CompletedRequirements, TotalRequirements]</MudText>
                <MudProgressLinear Color="@GetProgressColor()" Value="@CompletionPercent" Min="0" Max="100" />
            </div>
        </MudPaper>

        @if (NeedsProfileChanges)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                @L["ProfileChangesAlert"]
            </MudAlert>
        }
        else if (IsProfileInReview)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                @L["ProfileInReviewAlert"]
            </MudAlert>
        }

        <MudGrid Spacing="3">
            <MudItem xs="12" lg="4">
                <MudPaper Class="trust-panel" Elevation="0">
                    <MudText Typo="Typo.h6">@L["Checklist"]</MudText>
                    <MudStack Spacing="2">
                        @foreach (var requirement in _status.Requirements)
                        {
                            <div class="trust-requirement">
                                <MudIcon Icon="@(requirement.IsComplete ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)"
                                         Color="@(requirement.IsComplete ? Color.Success : Color.Secondary)" />
                                <div>
                                    <MudText Typo="Typo.subtitle2">@requirement.Label</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@GetRequirementHelp(requirement)</MudText>
                                </div>
                            </div>
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="8">
                <MudStack Spacing="3">
                    <MudPaper Class="trust-panel" Elevation="0">
                        <div class="trust-panel-heading">
                            <div>
                                <MudText Typo="Typo.h6">@L["Contact"]</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@L["ContactSubtitle"]</MudText>
                            </div>
                            <MudChip T="string" Color="@(_status.EmailVerified && _status.PhoneVerified ? Color.Success : Color.Warning)" Variant="Variant.Outlined">
                                @(_status.EmailVerified && _status.PhoneVerified ? L["Complete"] : L["Pending"])
                            </MudChip>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudStack Spacing="2">
                                    <MudText Typo="Typo.subtitle2">@L["Email"]</MudText>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="@(_status.EmailVerified || IsBusy(EmailRequestAction))" OnClick="RequestEmailAsync" StartIcon="@Icons.Material.Filled.MarkEmailRead">
                                        @L["RequestCode"]
                                    </MudButton>
                                    @if (_emailRequest?.MockCode is not null)
                                    {
                                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                                            @L["MockCodeLabel"] <strong>@_emailRequest.MockCode</strong>
                                        </MudAlert>
                                    }
                                    <MudTextField T="string" @bind-Value="_emailCode" Label="@L["EmailCode"]" Disabled="@_status.EmailVerified" MaxLength="6" Immediate="true" />
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_status.EmailVerified || string.IsNullOrWhiteSpace(_emailCode) || IsBusy(EmailConfirmAction))" OnClick="ConfirmEmailAsync">
                                        @L["ConfirmEmail"]
                                    </MudButton>
                                </MudStack>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudStack Spacing="2">
                                    <MudText Typo="Typo.subtitle2">WhatsApp</MudText>
                                    <MudChip T="string" Color="@(_status.PhoneVerified ? Color.Success : Color.Warning)" Variant="Variant.Outlined">
                                        @(_status.PhoneVerified ? "Telefono contactado" : "Pendiente de contacto")
                                    </MudChip>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        No enviaremos SMS ni codigos automaticos. Un administrador confirmara tu telefono por WhatsApp.
                                    </MudText>
                                    @if (!string.IsNullOrWhiteSpace(_status.ManualReview?.PhoneContactNotes))
                                    {
                                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                                            @_status.ManualReview.PhoneContactNotes
                                        </MudAlert>
                                    }
                                </MudStack>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    <MudPaper Class="trust-panel" Elevation="0">
                        <div class="trust-panel-heading">
                            <div>
                                <MudText Typo="Typo.h6">Datos declarados y evidencia</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Guarda solo datos minimos. La foto del documento se revisa por canal externo y no queda almacenada permanentemente.
                                </MudText>
                            </div>
                            <MudChip T="string" Color="@(_status.ManualEvidenceReviewed ? Color.Success : Color.Warning)" Variant="Variant.Outlined">
                                @(_status.ManualEvidenceReviewed ? "Evidencia revisada" : L["Pending"])
                            </MudChip>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" @bind-Value="_legalName" Label="Nombre legal" Disabled="@IsProfileInReview" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudTextField T="string" @bind-Value="_declaredCountry" Label="Pais" Disabled="@IsProfileInReview" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudTextField T="string" @bind-Value="_declaredCity" Label="Ciudad" Disabled="@IsProfileInReview" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" @bind-Value="_documentType" Label="@L["DocumentType"]" Disabled="@IsProfileInReview" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" @bind-Value="_documentNumberLast4" Label="Ultimos digitos del documento" MaxLength="4" Disabled="@IsProfileInReview" />
                            </MudItem>
                        </MudGrid>

                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-3">
                            Cuando el admin te contacte, podra pedir una foto temporal donde se vea tu rostro, el documento y una declaracion jurada con fecha. La plataforma solo registrara el resultado de la revision.
                        </MudAlert>

                        <MudCheckBox T="bool" @bind-Value="_acceptDeclaration" Disabled="@IsProfileInReview" Color="Color.Primary"
                                     Label="Declaro que los datos son reales, que el documento presentado me pertenece y autorizo revision manual para fines de seguridad." />
                    </MudPaper>

                    <MudPaper Class="trust-panel" Elevation="0">
                        <div class="trust-panel-heading">
                            <div>
                                <MudText Typo="Typo.h6">@L["RulesReview"]</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">El equipo revisara tus datos, evidencia externa, contacto WSP y entrevista.</MudText>
                            </div>
                            <MudChip T="string" Color="@(_status.ProfileValidated ? Color.Success : Color.Warning)" Variant="Variant.Outlined">
                                @(_status.ProfileValidated ? L["ProfileValidated"] : L["Unvalidated"])
                            </MudChip>
                        </div>

                        <MudStack Spacing="2">
                            <MudCheckBox T="bool" @bind-Value="_acceptCodeOfConduct" Disabled="@_status.CodeOfConductAccepted" Label="@L["AcceptCodeOfConduct"]" Color="Color.Primary" />
                            <MudCheckBox T="bool" @bind-Value="_acceptSafetyRules" Disabled="@_status.SafetyRulesAccepted" Label="@L["AcceptSafetyRules"]" Color="Color.Primary" />
                            <MudStack Row="true" Spacing="2" Class="action-row">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!CanAcceptRules || IsBusy(RulesAction))" OnClick="AcceptRulesAsync" StartIcon="@Icons.Material.Filled.Rule">
                                    @L["SaveAcceptance"]
                                </MudButton>
                                <MudButton Href="/guide/profile" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Badge">
                                    @L["EditProfile"]
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(!CanSubmitReview || IsBusy(ReviewAction))" OnClick="SubmitReviewAsync" StartIcon="@Icons.Material.Filled.Send">
                                    @GetReviewButtonText()
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudStack>
            </MudItem>
        </MudGrid>
    }
</MudStack>

@code {
    private const string EmailRequestAction = "email-request";
    private const string EmailConfirmAction = "email-confirm";
    private const string RulesAction = "rules";
    private const string ReviewAction = "review";

    private TrustStatusResponse? _status;
    private ContactVerificationResponse? _emailRequest;
    private string _emailCode = string.Empty;
    private string _legalName = string.Empty;
    private string _declaredCountry = string.Empty;
    private string _declaredCity = string.Empty;
    private string _documentType = "Passport";
    private string _documentNumberLast4 = string.Empty;
    private bool _acceptDeclaration;
    private bool _acceptCodeOfConduct;
    private bool _acceptSafetyRules;
    private bool _isLoading = true;
    private string? _busyAction;

    private int TotalRequirements => _status?.Requirements.Count ?? 0;
    private int CompletedRequirements => _status?.Requirements.Count(requirement => requirement.IsComplete) ?? 0;
    private double CompletionPercent => TotalRequirements == 0 ? 0 : CompletedRequirements * 100d / TotalRequirements;
    private bool NeedsProfileChanges => _status?.Status == "ProfileChangesRequested";
    private bool IsProfileInReview => _status?.Status == "InReview";
    private bool IsSuspended => _status?.Status == "Suspended";
    private bool CanAcceptRules => _status is not null
        && (!_status.CodeOfConductAccepted || !_status.SafetyRulesAccepted)
        && _acceptCodeOfConduct
        && _acceptSafetyRules;
    private bool CanSubmitReview => _status is { EmailVerified: true, CodeOfConductAccepted: true, SafetyRulesAccepted: true, ProfileValidated: false }
        && !IsProfileInReview
        && !IsSuspended
        && _acceptDeclaration
        && !string.IsNullOrWhiteSpace(_legalName)
        && !string.IsNullOrWhiteSpace(_declaredCountry)
        && !string.IsNullOrWhiteSpace(_declaredCity)
        && !string.IsNullOrWhiteSpace(_documentType)
        && !string.IsNullOrWhiteSpace(_documentNumberLast4);

    protected override Task OnInitializedAsync()
    {
        return LoadStatusAsync();
    }

    private async Task LoadStatusAsync()
    {
        _isLoading = true;
        var result = await TrustApi.GetMyStatusAsync();
        _isLoading = false;

        if (!result.Succeeded || result.Value is null)
        {
            Snackbar.Add(string.Join(" ", result.Errors), Severity.Error);
            _status = null;
            return;
        }

        ApplyStatus(result.Value);
    }

    private async Task RequestEmailAsync()
    {
        await RunAsync(EmailRequestAction, async () =>
        {
            var result = await TrustApi.RequestEmailVerificationAsync();
            if (!result.Succeeded || result.Value is null)
            {
                ShowErrors(result.Errors);
                return;
            }

            _emailRequest = result.Value;
            _emailCode = result.Value.MockCode ?? string.Empty;
            Snackbar.Add(L["EmailMockCodeGenerated"], Severity.Success);
        });
    }

    private async Task ConfirmEmailAsync()
    {
        await RunAsync(EmailConfirmAction, async () =>
        {
            var result = await TrustApi.ConfirmEmailVerificationAsync(new ConfirmContactVerificationRequest(_emailCode));
            if (!result.Succeeded || result.Value is null)
            {
                ShowErrors(result.Errors);
                return;
            }

            _emailRequest = null;
            _emailCode = string.Empty;
            ApplyStatus(result.Value);
            Snackbar.Add(L["EmailConfirmedSuccess"], Severity.Success);
        });
    }

    private async Task AcceptRulesAsync()
    {
        await RunAsync(RulesAction, async () =>
        {
            var result = await TrustApi.AcceptRulesAsync(new AcceptTrustRulesRequest(_acceptCodeOfConduct, _acceptSafetyRules));
            if (!result.Succeeded || result.Value is null)
            {
                ShowErrors(result.Errors);
                return;
            }

            ApplyStatus(result.Value);
            Snackbar.Add(L["RulesAccepted"], Severity.Success);
        });
    }

    private async Task SubmitReviewAsync()
    {
        await RunAsync(ReviewAction, async () =>
        {
            var wasResubmission = NeedsProfileChanges;
            var result = await TrustApi.SubmitGuideProfileReviewAsync(new SubmitManualGuideReviewRequest(
                _legalName,
                _declaredCountry,
                _declaredCity,
                _documentType,
                _documentNumberLast4,
                _acceptDeclaration));
            if (!result.Succeeded || result.Value is null)
            {
                ShowErrors(result.Errors);
                return;
            }

            ApplyStatus(result.Value);
            Snackbar.Add(wasResubmission ? L["ProfileResubmittedReview"] : L["ProfileSubmittedReview"], Severity.Success);
        });
    }

    private async Task RunAsync(string action, Func<Task> work)
    {
        try
        {
            _busyAction = action;
            await work();
        }
        finally
        {
            _busyAction = null;
        }
    }

    private bool IsBusy(string action)
    {
        return string.Equals(_busyAction, action, StringComparison.Ordinal);
    }

    private void ApplyStatus(TrustStatusResponse status)
    {
        _status = status;
        _acceptCodeOfConduct = status.CodeOfConductAccepted || _acceptCodeOfConduct;
        _acceptSafetyRules = status.SafetyRulesAccepted || _acceptSafetyRules;
        if (status.ManualReview is not null)
        {
            _legalName = status.ManualReview.LegalName ?? _legalName;
            _declaredCountry = status.ManualReview.Country ?? _declaredCountry;
            _declaredCity = status.ManualReview.City ?? _declaredCity;
            _documentType = status.ManualReview.DocumentType ?? _documentType;
            _documentNumberLast4 = status.ManualReview.DocumentNumberLast4 ?? _documentNumberLast4;
            _acceptDeclaration = status.ManualReview.DeclarationAccepted || _acceptDeclaration;
        }
    }

    private void ShowErrors(IReadOnlyCollection<string> errors)
    {
        Snackbar.Add(string.Join(" ", errors), Severity.Error);
    }

    private Color GetProgressColor()
    {
        if (_status?.Status == "Suspended")
        {
            return Color.Error;
        }

        if (_status?.Status == "ProfileChangesRequested")
        {
            return Color.Warning;
        }

        return CompletionPercent >= 100 ? Color.Success : Color.Primary;
    }

    private string GetReviewHelpText()
    {
        if (NeedsProfileChanges)
        {
            return L["ReviewHelpChanges"];
        }

        if (IsProfileInReview)
        {
            return L["ReviewHelpInReview"];
        }

        return L["ReviewHelpDefault"];
    }

    private string GetReviewButtonText()
    {
        if (NeedsProfileChanges)
        {
            return L["ResubmitReview"];
        }

        if (IsProfileInReview)
        {
            return L["InReview"];
        }

        return L["SubmitReview"];
    }

    private string GetStatusLabel(string status)
    {
        return status switch
        {
            "Unverified" => L["StatusUnverified"],
            "ContactVerified" => L["StatusContactVerified"],
            "IdentityVerified" => L["StatusIdentityVerified"],
            "ProfileValidated" => L["StatusProfileValidated"],
            "InReview" => L["InReview"],
            "ProfileChangesRequested" => L["StatusProfileChangesRequested"],
            "Suspended" => L["StatusSuspended"],
            _ => status
        };
    }

    private string GetRequirementHelp(TrustRequirementResponse requirement)
    {
        if (requirement.IsComplete)
        {
            return L["Ready"];
        }

        return requirement.Action switch
        {
            "request-email-code" => L["ReqEmailHelp"],
            "manual-whatsapp-contact" => "El administrador validara tu telefono por WhatsApp.",
            "manual-evidence-review" => "El administrador revisara la evidencia enviada por canal externo.",
            "manual-interview" => "El administrador registrara la entrevista manual.",
            "accept-trust-rules" => L["ReqRulesHelp"],
            "submit-guide-profile-review" => L["ReqReviewHelp"],
            _ => L["Pending"]
        };
    }
}
