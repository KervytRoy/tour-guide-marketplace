@page "/bookings"
@attribute [Authorize(Roles = AppRoles.Tourist)]
@inject IStringLocalizer<SharedResource> L

<MudPaper Class="state-panel" Elevation="0">
    <MudIcon Icon="@Icons.Material.Filled.EventAvailable" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h5">@L["MyBookings"]</MudText>
    <MudText Color="Color.Secondary">@L["MyBookingsComingSoon"]</MudText>
</MudPaper>
