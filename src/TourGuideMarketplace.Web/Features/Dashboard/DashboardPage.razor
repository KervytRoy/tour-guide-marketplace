@page "/dashboard"
@attribute [Authorize]
@inject CurrentUserState CurrentUser
@inject IStringLocalizer<SharedResource> L

<MudStack Spacing="3">
    <div class="page-heading">
        <div>
            <MudText Typo="Typo.h4">@L["Dashboard"]</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                @L["DashboardGreeting", _user?.FullName ?? L["WelcomeFallback"]]
            </MudText>
        </div>
    </div>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="4">
            <MudPaper Class="metric-card" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Primary" />
                <MudText Typo="Typo.subtitle2">@L["Account"]</MudText>
                <MudText Typo="Typo.h6">@string.Join(", ", _user?.Roles ?? [])</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="metric-card" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.EventAvailable" Color="Color.Secondary" />
                <MudText Typo="Typo.subtitle2">@L["Bookings"]</MudText>
                <MudText Typo="Typo.h6">@L["ReadyForNextModules"]</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="metric-card" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.NotificationsActive" Color="Color.Success" />
                <MudText Typo="Typo.subtitle2">@L["Activity"]</MudText>
                <MudText Typo="Typo.h6">@L["NoPendingAlerts"]</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <AuthorizeView Roles="@AppRoles.Tourist">
        <Authorized>
            <MudPaper Class="work-panel" Elevation="0">
                <MudText Typo="Typo.h6">@L["TouristStartTitle"]</MudText>
                <MudText Color="Color.Secondary">@L["TouristStartDescription"]</MudText>
                <MudStack Row="true" Spacing="2" Class="action-row">
                    <MudButton Href="/guides" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.TravelExplore">
                        @L["SearchGuides"]
                    </MudButton>
                    <MudButton Href="/tourist/profile" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ManageAccounts">
                        @L["CompleteProfile"]
                    </MudButton>
                </MudStack>
            </MudPaper>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@AppRoles.Guide">
        <Authorized>
            <MudPaper Class="work-panel" Elevation="0">
                <MudText Typo="Typo.h6">@L["GuideStartTitle"]</MudText>
                <MudText Color="Color.Secondary">@L["GuideStartDescription"]</MudText>
                <MudStack Row="true" Spacing="2" Class="action-row">
                    <MudButton Href="/guide/trust" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.VerifiedUser">
                        @L["ValidateIdentity"]
                    </MudButton>
                    <MudButton Href="/guide/profile" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Badge">
                        @L["MyGuideProfile"]
                    </MudButton>
                    <MudButton Href="/guide/bookings" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.EventNote">
                        @L["ReceivedBookings"]
                    </MudButton>
                </MudStack>
            </MudPaper>
        </Authorized>
    </AuthorizeView>
</MudStack>

@code {
    private CurrentUserResponse? _user;

    protected override async Task OnInitializedAsync()
    {
        var result = await CurrentUser.LoadAsync();
        _user = result.Value;
    }
}
