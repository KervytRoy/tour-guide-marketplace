@page "/dashboard"
@attribute [Authorize]
@inject CurrentUserState CurrentUser

<MudStack Spacing="3">
    <div class="page-heading">
        <div>
            <MudText Typo="Typo.h4">Dashboard</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                Hola, @(_user?.FullName ?? "bienvenido"). Este es tu punto de inicio.
            </MudText>
        </div>
    </div>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="4">
            <MudPaper Class="metric-card" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Primary" />
                <MudText Typo="Typo.subtitle2">Cuenta</MudText>
                <MudText Typo="Typo.h6">@string.Join(", ", _user?.Roles ?? [])</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="metric-card" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.EventAvailable" Color="Color.Secondary" />
                <MudText Typo="Typo.subtitle2">Reservas</MudText>
                <MudText Typo="Typo.h6">Preparado para proximos modulos</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="metric-card" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.NotificationsActive" Color="Color.Success" />
                <MudText Typo="Typo.subtitle2">Actividad</MudText>
                <MudText Typo="Typo.h6">Sin alertas pendientes</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <AuthorizeView Roles="@AppRoles.Tourist">
        <Authorized>
            <MudPaper Class="work-panel" Elevation="0">
                <MudText Typo="Typo.h6">Inicio para turistas</MudText>
                <MudText Color="Color.Secondary">Explora guias disponibles y completa tu perfil para futuras reservas.</MudText>
                <MudStack Row="true" Spacing="2" Class="action-row">
                    <MudButton Href="/guides" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.TravelExplore">
                        Buscar guias
                    </MudButton>
                    <MudButton Href="/tourist/profile" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ManageAccounts">
                        Completar perfil
                    </MudButton>
                </MudStack>
            </MudPaper>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@AppRoles.Guide">
        <Authorized>
            <MudPaper Class="work-panel" Elevation="0">
                <MudText Typo="Typo.h6">Inicio para guias</MudText>
                <MudText Color="Color.Secondary">Mantén tu perfil publicado y listo para recibir solicitudes.</MudText>
                <MudStack Row="true" Spacing="2" Class="action-row">
                    <MudButton Href="/guide/trust" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.VerifiedUser">
                        Validar identidad
                    </MudButton>
                    <MudButton Href="/guide/profile" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Badge">
                        Mi perfil de guia
                    </MudButton>
                    <MudButton Href="/guide/bookings" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.EventNote">
                        Reservas recibidas
                    </MudButton>
                </MudStack>
            </MudPaper>
        </Authorized>
    </AuthorizeView>
</MudStack>

@code {
    private CurrentUserResponse? _user;

    protected override async Task OnInitializedAsync()
    {
        var result = await CurrentUser.LoadAsync();
        _user = result.Value;
    }
}
