@inherits LayoutComponentBase
@inject AuthSessionService AuthSession
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject CurrentUserState CurrentUser
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudLayout Class="app-shell">
    <MudAppBar Class="app-topbar" Elevation="0">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="brand-title">Tour Guide Marketplace</MudText>
        <MudSpacer />
        @if (_isAuthenticated)
        {
            <MudText Typo="Typo.body2" Class="user-name">@(_currentUser?.FullName ?? _displayName ?? "Cuenta")</MudText>
            <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit">
                <MudMenuItem Href="/profile" Icon="@Icons.Material.Filled.Person">Perfil</MudMenuItem>
                <MudMenuItem OnClick="LogoutAsync" Icon="@Icons.Material.Filled.Logout">Cerrar sesion</MudMenuItem>
            </MudMenu>
        }
        else
        {
            <div class="public-actions">
                <MudButton Href="/login" Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Login">
                    Ingresar
                </MudButton>
                <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd">
                    Crear cuenta
                </MudButton>
            </div>
        }
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md" Elevation="0" Class="app-drawer">
        <div class="drawer-brand">
            <MudIcon Icon="@Icons.Material.Filled.Explore" Color="Color.Primary" />
            <div>
                <MudText Typo="Typo.subtitle1">Marketplace</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Turistas y guias</MudText>
            </div>
        </div>

        <MudNavMenu Class="nav-menu">
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Explore">
                Inicio
            </MudNavLink>

            <AuthorizeView>
                <Authorized>
                    <MudNavLink Href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.SpaceDashboard">
                        Dashboard
                    </MudNavLink>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView Roles="@AppRoles.Tourist">
                <Authorized>
                    <MudNavLink Href="/guides" Icon="@Icons.Material.Filled.TravelExplore">
                        Buscar guias
                    </MudNavLink>
                    <MudNavLink Href="/tourist/profile" Icon="@Icons.Material.Filled.ManageAccounts">
                        Mi perfil turista
                    </MudNavLink>
                    <MudNavLink Href="/bookings" Icon="@Icons.Material.Filled.EventAvailable">
                        Mis reservas
                    </MudNavLink>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView Roles="@AppRoles.Guide">
                <Authorized>
                    <MudNavLink Href="/guide/profile" Icon="@Icons.Material.Filled.Badge">
                        Mi perfil de guia
                    </MudNavLink>
                    <MudNavLink Href="/guide/trust" Icon="@Icons.Material.Filled.VerifiedUser">
                        Validacion de identidad
                    </MudNavLink>
                    <MudNavLink Href="/guide/bookings" Icon="@Icons.Material.Filled.EventNote">
                        Reservas recibidas
                    </MudNavLink>
                    <MudNavLink Href="/guide/reviews" Icon="@Icons.Material.Filled.RateReview">
                        Resenas
                    </MudNavLink>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView>
                <Authorized>
                    <MudDivider Class="my-3" />
                    <MudNavLink Href="/profile" Icon="@Icons.Material.Filled.Person">
                        Perfil
                    </MudNavLink>
                </Authorized>
                <NotAuthorized>
                    <MudDivider Class="my-3" />
                    <MudNavLink Href="/login" Icon="@Icons.Material.Filled.Login">
                        Ingresar
                    </MudNavLink>
                    <MudNavLink Href="/register" Icon="@Icons.Material.Filled.PersonAdd">
                        Crear cuenta
                    </MudNavLink>
                </NotAuthorized>
            </AuthorizeView>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="content-container">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isAuthenticated;
    private CurrentUserResponse? _currentUser;
    private string? _displayName;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
        _displayName = authState.User.Identity?.Name;

        if (_isAuthenticated)
        {
            var result = await CurrentUser.LoadAsync();
            if (result.Succeeded)
            {
                _currentUser = result.Value;
            }
        }
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task LogoutAsync()
    {
        await AuthSession.LogoutAsync();
        CurrentUser.Clear();
        Snackbar.Add("Sesion cerrada.", Severity.Info);
        Navigation.NavigateTo("/");
    }
}
