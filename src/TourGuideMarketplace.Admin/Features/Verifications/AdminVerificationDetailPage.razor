@page "/admin/verifications/{UserId:guid}"
@attribute [Authorize(Roles = AppRoles.Admin)]
@inject AdminVerificationsApiClient VerificationsApi
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResource> L

<MudStack Spacing="3">
    <div class="page-heading">
        <div>
            <MudText Typo="Typo.h4">@L["VerificationDetailTitle"]</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                @L["VerificationDetailSubtitle"]
            </MudText>
        </div>
        <MudStack Row="true" Spacing="2" Class="action-row">
            <MudButton Href="/admin/verifications" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack">
                @L["Back"]
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isLoading" OnClick="LoadAsync" StartIcon="@Icons.Material.Filled.Refresh">
                @L["Refresh"]
            </MudButton>
        </MudStack>
    </div>

    @if (_isLoading)
    {
        <div class="app-loading">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else if (_detail is null)
    {
        <MudPaper Class="state-panel" Elevation="0">
            <MudIcon Icon="@Icons.Material.Filled.CloudOff" Color="Color.Warning" Size="Size.Large" />
            <MudText Typo="Typo.h6">@L["DetailLoadFailed"]</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAsync">
                @L["Retry"]
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="detail-hero" Elevation="0">
            <div class="identity-cell">
                <MudAvatar Color="Color.Primary" Size="Size.Large">@GetInitials(_detail.FullName)</MudAvatar>
                <div>
                    <MudText Typo="Typo.h5">@_detail.FullName</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_detail.Email</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@(_detail.PhoneNumber ?? L["NoPhone"])</MudText>
                </div>
            </div>
            <MudChip T="string" Color="@GetStatusColor(_detail.TrustStatus.Status)" Variant="Variant.Filled">
                @GetStatusLabel(_detail.TrustStatus.Status)
            </MudChip>
        </MudPaper>

        <MudGrid Spacing="3">
            <MudItem xs="12" md="8">
                <MudStack Spacing="3">
                    <MudPaper Class="work-panel" Elevation="0">
                        <div class="panel-heading">
                            <div>
                                <MudText Typo="Typo.h6">@L["TrustChecklist"]</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@L["TrustChecklistSubtitle"]</MudText>
                            </div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@L["RequirementsProgress", CompletedRequirements, TotalRequirements]</MudText>
                        </div>

                        <MudProgressLinear Color="@GetProgressColor()" Value="@CompletionPercent" Min="0" Max="100" Class="mb-4" />

                        <MudGrid Spacing="2">
                            @foreach (var requirement in _detail.TrustStatus.Requirements)
                            {
                                <MudItem xs="12" md="6">
                                    <div class="requirement-row">
                                        <MudIcon Icon="@(requirement.IsComplete ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)"
                                                 Color="@(requirement.IsComplete ? Color.Success : Color.Secondary)" />
                                        <div>
                                            <MudText Typo="Typo.subtitle2">@requirement.Label</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@GetRequirementHelp(requirement)</MudText>
                                        </div>
                                    </div>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudPaper>

                    <MudPaper Class="work-panel" Elevation="0">
                        <div class="panel-heading">
                            <div>
                                <MudText Typo="Typo.h6">Flujo guiado de validacion</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Acompana la llamada por WhatsApp con preguntas, checks, comparacion contra perfil y observaciones accionables.</MudText>
                            </div>
                            <MudStack Row="true" Spacing="2" Class="action-row">
                                <MudButton Href="@GetWhatsAppLink()" Target="_blank" Variant="Variant.Outlined" Color="Color.Success"
                                           Disabled="@string.IsNullOrWhiteSpace(_detail.PhoneNumber)" StartIcon="@Icons.Material.Filled.Chat">
                                    Abrir WhatsApp
                                </MudButton>
                                <MudChip T="string" Color="@(_detail.ManualReview?.CanApprove == true ? Color.Success : Color.Warning)" Variant="Variant.Outlined">
                                    @(_detail.ManualReview?.CanApprove == true ? "Listo para aprobar" : "Pendiente")
                                </MudChip>
                            </MudStack>
                        </div>

                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3">
                            Las observaciones internas quedan en notas. Si marcas una correccion, el motivo se convierte en alerta para el guia con la seccion afectada y como arreglarla.
                        </MudAlert>

                        @if (_detail.GuideProfile is null)
                        {
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-3">
                                Este usuario aun no tiene perfil de guia guardado. La validacion puede registrar la llamada, pero no se podra comparar biografia, servicios, idiomas o tarifa.
                            </MudAlert>
                        }

                        <MudStack Spacing="3" Class="manual-validation-flow">
                            <section class="validation-module">
                                <div class="validation-module-heading">
                                    <MudText Typo="Typo.subtitle1">1. Contacto por WhatsApp</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Pregunta: puedes confirmar que este es tu numero principal para reservas?</MudText>
                                </div>

                                <ProfileVerificationField Label="Telefono"
                                                          ProfileValue="@(_detail.PhoneNumber ?? "-")"
                                                          ComparisonValue="@GetPhoneContactStatusLabel(_phoneContactStatus)"
                                                          RequiresCorrection="@IsPhoneContactCorrectionSuggested()" />

                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="6">
                                        <MudSelect T="string" @bind-Value="_phoneContactStatus" Label="Resultado del contacto WSP">
                                            <MudSelectItem T="string" Value="@("Pending")">Pendiente</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("Responded")">Si, respondio</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("NoResponse")">No respondio</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("NumberDoesNotExist")">El numero no existe</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("WrongNumber")">Numero equivocado</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("Busy")">Ocupado</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("DifferentPerson")">Responde otra persona</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("RescheduleRequested")">Solicita reprogramar</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string" @bind-Value="_phoneContactNotes" Label="Observaciones WSP" Lines="3" />
                                    </MudItem>
                                </MudGrid>

                                <MudCheckBox T="bool" @bind-Value="_phoneCorrection.Selected" Label="Pedir correccion del telefono al usuario" Color="Color.Warning" />
                            </section>

                            <section class="validation-module">
                                <div class="validation-module-heading">
                                    <MudText Typo="Typo.subtitle1">2. Identidad y datos declarados</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Pregunta: confirma tu nombre, ciudad, pais y documento declarado.</MudText>
                                </div>

                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="6">
                                        <ProfileVerificationField Label="Nombre"
                                                                  ProfileValue="@_detail.FullName"
                                                                  ComparisonLabel="Declarado"
                                                                  ComparisonValue="@(_detail.ManualReview?.LegalName ?? "-")"
                                                                  RequiresCorrection="@(!_declaredDataReviewed)" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <ProfileVerificationField Label="Ubicacion"
                                                                  ProfileValue="@GetGuideLocation()"
                                                                  ComparisonLabel="Declarado"
                                                                  ComparisonValue="@GetDeclaredLocation()"
                                                                  RequiresCorrection="@(!_declaredDataReviewed)" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <ProfileVerificationField Label="Documento"
                                                                  ProfileValue="@GetDeclaredDocument()"
                                                                  ComparisonLabel="Resultado"
                                                                  ComparisonValue="@(_declaredDataReviewed ? "Confirmado" : "Pendiente o inconsistente")"
                                                                  RequiresCorrection="@(!_declaredDataReviewed)" />
                                    </MudItem>
                                    <MudItem xs="12" md="6" Class="validation-checks">
                                        <MudCheckBox T="bool" @bind-Value="_declaredDataReviewed" Label="Datos declarados revisados y consistentes" Color="Color.Primary" />
                                        <MudCheckBox T="bool" @bind-Value="_identityCorrection.Selected" Label="Pedir correccion de identidad/datos declarados" Color="Color.Warning" />
                                    </MudItem>
                                </MudGrid>
                            </section>

                            <section class="validation-module">
                                <div class="validation-module-heading">
                                    <MudText Typo="Typo.subtitle1">3. Perfil del guia</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Pregunta: explica tus servicios, experiencia, idiomas, disponibilidad y tarifa.</MudText>
                                </div>

                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="6">
                                        <ProfileVerificationField Label="Biografia"
                                                                  ProfileValue="@Summarize(_detail.GuideProfile?.Bio)"
                                                                  ComparisonLabel="Llamada"
                                                                  ComparisonValue="@(_profileCoherent ? "Coherente" : "Pendiente o no coincide")"
                                                                  RequiresCorrection="@(!_profileCoherent)" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <ProfileVerificationField Label="Servicios"
                                                                  ProfileValue="@JoinValues(_detail.GuideProfile?.Specialties)"
                                                                  ComparisonLabel="Llamada"
                                                                  ComparisonValue="@(_profileCoherent ? "Confirmados" : "Revisar")"
                                                                  RequiresCorrection="@(!_profileCoherent)" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <ProfileVerificationField Label="Idiomas"
                                                                  ProfileValue="@JoinValues(_detail.GuideProfile?.Languages)"
                                                                  ComparisonLabel="Llamada"
                                                                  ComparisonValue="@(_profileCoherent ? "Confirmados" : "Revisar")"
                                                                  RequiresCorrection="@(!_profileCoherent)" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <ProfileVerificationField Label="Tarifa y disponibilidad"
                                                                  ProfileValue="@GetRateAndAvailability()"
                                                                  ComparisonLabel="Llamada"
                                                                  ComparisonValue="@(_profileCoherent ? "Confirmada" : "Revisar")"
                                                                  RequiresCorrection="@(!_profileCoherent)" />
                                    </MudItem>
                                    <MudItem xs="12" md="6" Class="validation-checks">
                                        <MudCheckBox T="bool" @bind-Value="_profileCoherent" Label="Perfil coherente con la declaracion y la llamada" Color="Color.Primary" />
                                        <MudCheckBox T="bool" @bind-Value="_referencesReviewed" Label="Referencias revisadas" Color="Color.Primary" />
                                    </MudItem>
                                    <MudItem xs="12" md="6" Class="validation-checks">
                                        <MudCheckBox T="bool" @bind-Value="_profileCorrection.Selected" Label="Pedir correccion del perfil del guia" Color="Color.Warning" />
                                    </MudItem>
                                </MudGrid>
                            </section>

                            <section class="validation-module">
                                <div class="validation-module-heading">
                                    <MudText Typo="Typo.subtitle1">4. Evidencia externa</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Pregunta: envia por el canal acordado una evidencia temporal clara y consistente.</MudText>
                                </div>

                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="6">
                                        <ProfileVerificationField Label="Evidencia vs declaracion"
                                                                  ProfileValue="@GetDeclaredDocument()"
                                                                  ComparisonLabel="Revision"
                                                                  ComparisonValue="@GetEvidenceReviewStatusLabel(_evidenceReviewStatus)"
                                                                  RequiresCorrection="@IsEvidenceCorrectionSuggested()" />
                                    </MudItem>
                                    <MudItem xs="12" md="6" Class="validation-checks">
                                        <MudCheckBox T="bool" @bind-Value="_evidenceReceived" Label="Evidencia recibida por canal externo" Color="Color.Primary" />
                                        <MudSelect T="string" @bind-Value="_evidenceReviewStatus" Label="Resultado evidencia">
                                            <MudSelectItem T="string" Value="@("Pending")">Pendiente</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("Received")">Recibida</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("MatchesDeclaration")">Coincide con declaracion</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("Inconclusive")">No concluyente</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("Inconsistent")">Inconsistente</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("Rejected")">Rechazada</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudTextField T="string" @bind-Value="_evidenceNotes" Label="Observaciones evidencia" Lines="3" />
                                        <MudCheckBox T="bool" @bind-Value="_evidenceCorrection.Selected" Label="Pedir correccion de evidencia al usuario" Color="Color.Warning" />
                                    </MudItem>
                                </MudGrid>
                            </section>

                            <section class="validation-module">
                                <div class="validation-module-heading">
                                    <MudText Typo="Typo.subtitle1">5. Entrevista y cierre</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Pregunta: confirma que entiende el funcionamiento, reglas y proximo paso de validacion.</MudText>
                                </div>

                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="6">
                                        <MudSelect T="string" @bind-Value="_manualInterviewStatus" Label="Estado entrevista">
                                            <MudSelectItem T="string" Value="@("Pending")">Pendiente</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("Scheduled")">Agendada</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("Completed")">Completada</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("NoShow")">No asistio</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("Cancelled")">Cancelada</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("RequiresFollowUp")">Requiere seguimiento</MudSelectItem>
                                        </MudSelect>
                                        <MudSelect T="string" @bind-Value="_manualInterviewResult" Label="Resultado entrevista">
                                            <MudSelectItem T="string" Value="@("None")">Sin resultado</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("Passed")">Aprobada</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("Inconclusive")">No concluyente</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("Failed")">Fallida</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("RequiresFollowUp")">Requiere seguimiento</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField T="string" @bind-Value="_manualInterviewChannel" Label="Canal" />
                                        <MudTextField T="string" @bind-Value="_manualInterviewReference" Label="Referencia" />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudTextField T="string" @bind-Value="_manualInterviewNotes" Label="Observaciones entrevista" Lines="3" />
                                        <MudCheckBox T="bool" @bind-Value="_interviewCorrection.Selected" Label="Pedir seguimiento o nueva entrevista al usuario" Color="Color.Warning" />
                                    </MudItem>
                                </MudGrid>
                            </section>
                        </MudStack>

                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@IsBusy(ManualReviewAction)"
                                   OnClick="SaveManualReviewAsync" StartIcon="@Icons.Material.Filled.Save" Class="mt-3">
                            Guardar revision manual
                        </MudButton>
                    </MudPaper>

                    <MudPaper Class="work-panel" Elevation="0">
                        <div class="panel-heading">
                            <div>
                                <MudText Typo="Typo.h6">@L["IdentityAttempts"]</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@L["IdentityAttemptsSubtitle"]</MudText>
                            </div>
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">@L["AttemptsCount", _detail.Attempts.Count]</MudChip>
                        </div>

                        @if (_detail.Attempts.Count == 0)
                        {
                            <MudText Color="Color.Secondary">@L["NoIdentityAttempts"]</MudText>
                        }
                        else
                        {
                            <MudTable Items="_detail.Attempts" Hover="true" Dense="true" Elevation="0">
                                <HeaderContent>
                                    <MudTh>@L["Provider"]</MudTh>
                                    <MudTh>@L["Status"]</MudTh>
                                    <MudTh>@L["Document"]</MudTh>
                                    <MudTh>@L["Reference"]</MudTh>
                                    <MudTh>@L["Date"]</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="attempt">
                                    <MudTd DataLabel="@L["Provider"]">@attempt.Provider</MudTd>
                                    <MudTd DataLabel="@L["Status"]">
                                        <MudChip T="string" Color="@GetAttemptColor(attempt.Status)" Variant="Variant.Outlined">
                                            @GetAttemptLabel(attempt.Status)
                                        </MudChip>
                                        @if (!string.IsNullOrWhiteSpace(attempt.FailureReason))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@attempt.FailureReason</MudText>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="@L["Document"]">
                                        <MudText Typo="Typo.body2">@attempt.Country / @attempt.DocumentType</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">**** @attempt.DocumentNumberLast4</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@L["Reference"]">
                                        <MudText Typo="Typo.caption" Class="mono">@attempt.ExternalVerificationId</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@L["Date"]">@FormatDate(attempt.RequestedAt)</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudPaper>

                    <MudPaper Class="work-panel" Elevation="0">
                        <div class="panel-heading">
                            <div>
                                <MudText Typo="Typo.h6">@L["AdminCases"]</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@L["AdminCasesSubtitle"]</MudText>
                            </div>
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">@L["OpenCasesCount", OpenCaseCount]</MudChip>
                        </div>

                        @if (_detail.ReviewCases.Count == 0)
                        {
                            <MudText Color="Color.Secondary">@L["NoReviewCases"]</MudText>
                        }
                        else
                        {
                            <MudStack Spacing="2">
                                @foreach (var reviewCase in _detail.ReviewCases)
                                {
                                    <div class="case-row">
                                        <MudIcon Icon="@(reviewCase.Status == "Open" ? Icons.Material.Filled.PendingActions : Icons.Material.Filled.TaskAlt)"
                                                 Color="@(reviewCase.Status == "Open" ? Color.Warning : Color.Success)" />
                                        <div>
                                            <MudText Typo="Typo.subtitle2">@GetCaseTypeLabel(reviewCase.Type) - @GetCaseStatusLabel(reviewCase.Status)</MudText>
                                            <MudText Typo="Typo.body2">@reviewCase.Reason</MudText>
                                            @if (!string.IsNullOrWhiteSpace(reviewCase.Notes))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@reviewCase.Notes</MudText>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(reviewCase.Decision))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Success">@reviewCase.Decision</MudText>
                                            }
                                        </div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatDate(reviewCase.CreatedAt)</MudText>
                                    </div>
                                }
                            </MudStack>
                        }
                    </MudPaper>
                </MudStack>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudStack Spacing="3">
                    <MudPaper Class="work-panel" Elevation="0">
                        <MudText Typo="Typo.h6">@L["QuickStatus"]</MudText>
                        <div class="quick-status-grid">
                            <StatusIndicator Label="@L["Email"]" Value="@_detail.TrustStatus.EmailVerified" />
                            <StatusIndicator Label="WSP" Value="@_detail.TrustStatus.PhoneVerified" />
                            <StatusIndicator Label="Evidencia" Value="@_detail.TrustStatus.ManualEvidenceReviewed" />
                            <StatusIndicator Label="Entrevista" Value="@_detail.TrustStatus.ManualInterviewCompleted" />
                            <StatusIndicator Label="@L["Profile"]" Value="@_detail.TrustStatus.ProfileValidated" />
                            <StatusIndicator Label="@L["Conduct"]" Value="@_detail.TrustStatus.CodeOfConductAccepted" />
                            <StatusIndicator Label="@L["Safety"]" Value="@_detail.TrustStatus.SafetyRulesAccepted" />
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_detail.TrustStatus.InReviewReason))
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-3">
                                @_detail.TrustStatus.InReviewReason
                            </MudAlert>
                        }

                        @if (!string.IsNullOrWhiteSpace(_detail.TrustStatus.SuspendedReason))
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-3">
                                @_detail.TrustStatus.SuspendedReason
                            </MudAlert>
                        }
                    </MudPaper>

                    <MudPaper Class="work-panel" Elevation="0">
                        <MudText Typo="Typo.h6">@L["AdminDecision"]</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @L["AdminDecisionSubtitle"]
                        </MudText>

                        <MudTextField T="string" @bind-Value="_reason" Label="@L["Reason"]" Lines="3" />
                        @if (CorrectionItems.Any(item => item.Selected))
                        {
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mt-3">
                                <MudText Typo="Typo.subtitle2">Alerta que recibira el guia</MudText>
                                <MudText Typo="Typo.body2">@BuildSelectedCorrectionMessage()</MudText>
                            </MudAlert>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="UseCorrectionMessageAsReason" StartIcon="@Icons.Material.Filled.AutoFixHigh">
                                Usar mensaje sugerido
                            </MudButton>
                        }
                        <MudTextField T="string" @bind-Value="_notes" Label="@L["InternalNotes"]" Lines="3" />

                        <MudStack Spacing="2" Class="decision-actions">
                            <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(!CanApprove || IsBusy(ApproveAction))"
                                       OnClick="@(() => ExecuteDecisionAsync(ApproveAction))" StartIcon="@Icons.Material.Filled.CheckCircle">
                                @L["ApproveProfile"]
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Warning" Disabled="@(!CanReject || IsBusy(RejectAction))"
                                       OnClick="@(() => ExecuteDecisionAsync(RejectAction))" StartIcon="@Icons.Material.Filled.ReportProblem">
                                @L["RequestProfileChanges"]
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Disabled="@(!CanSuspend || IsBusy(SuspendAction))"
                                       OnClick="@(() => ExecuteDecisionAsync(SuspendAction))" StartIcon="@Icons.Material.Filled.Block">
                                @L["SuspendAccount"]
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="@(!CanReactivate || IsBusy(ReactivateAction))"
                                       OnClick="@(() => ExecuteDecisionAsync(ReactivateAction))" StartIcon="@Icons.Material.Filled.RestartAlt">
                                @L["ReactivateAccount"]
                            </MudButton>
                        </MudStack>

                        @if (RequiresReason)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @L["ReasonRequiredHelp"]
                            </MudText>
                        }
                    </MudPaper>
                </MudStack>
            </MudItem>
        </MudGrid>
    }
</MudStack>

@code {
    private const string ApproveAction = "approve";
    private const string RejectAction = "reject";
    private const string SuspendAction = "suspend";
    private const string ReactivateAction = "reactivate";
    private const string ManualReviewAction = "manual-review";

    private AdminVerificationDetailResponse? _detail;
    private string _reason = string.Empty;
    private string _notes = string.Empty;
    private string _phoneContactStatus = "Pending";
    private string _phoneContactNotes = string.Empty;
    private bool _evidenceReceived;
    private string _evidenceReviewStatus = "Pending";
    private string _evidenceNotes = string.Empty;
    private bool _declaredDataReviewed;
    private bool _profileCoherent;
    private bool _referencesReviewed;
    private string _manualInterviewStatus = "Pending";
    private string _manualInterviewResult = "None";
    private string _manualInterviewChannel = string.Empty;
    private string _manualInterviewReference = string.Empty;
    private string _manualInterviewNotes = string.Empty;
    private bool _isLoading;
    private string? _busyAction;
    private readonly CorrectionItem _phoneCorrection = new(
        "Telefono de contacto",
        "No pudimos validar el numero registrado por WhatsApp.",
        "Ingresa un numero activo con WhatsApp y guardalo en tu perfil antes de reenviar la solicitud.");
    private readonly CorrectionItem _identityCorrection = new(
        "Identidad",
        "Los datos declarados no coinciden con la informacion confirmada durante la validacion.",
        "Revisa tu nombre legal, pais, ciudad y documento declarado en la seccion de validacion.");
    private readonly CorrectionItem _profileCorrection = new(
        "Perfil del guia",
        "La informacion del perfil no es coherente con lo confirmado durante la llamada.",
        "Actualiza tu biografia, ciudad, servicios, idiomas, tarifa o disponibilidad segun corresponda.");
    private readonly CorrectionItem _evidenceCorrection = new(
        "Evidencia",
        "La evidencia enviada por canal externo esta incompleta o no coincide con tu declaracion.",
        "Envia una evidencia clara y consistente cuando el equipo te contacte nuevamente.");
    private readonly CorrectionItem _interviewCorrection = new(
        "Entrevista",
        "La entrevista manual quedo pendiente o no fue concluyente.",
        "Coordina una nueva llamada por WhatsApp y confirma los datos solicitados.");

    [Parameter]
    public Guid UserId { get; set; }

    private int TotalRequirements => _detail?.TrustStatus.Requirements.Count ?? 0;
    private int CompletedRequirements => _detail?.TrustStatus.Requirements.Count(requirement => requirement.IsComplete) ?? 0;
    private double CompletionPercent => TotalRequirements == 0 ? 0 : CompletedRequirements * 100d / TotalRequirements;
    private int OpenCaseCount => _detail?.ReviewCases.Count(reviewCase => reviewCase.Status == "Open") ?? 0;
    private IReadOnlyCollection<CorrectionItem> CorrectionItems =>
    [
        _phoneCorrection,
        _identityCorrection,
        _profileCorrection,
        _evidenceCorrection,
        _interviewCorrection
    ];

    private bool HasUserCorrectionReason => !string.IsNullOrWhiteSpace(_reason) || CorrectionItems.Any(item => item.Selected);
    private bool RequiresReason => !HasUserCorrectionReason;
    private bool CanApprove => _detail?.TrustStatus is { ProfileValidated: false, Status: "InReview" }
        && _detail.ManualReview?.CanApprove == true;
    private bool CanReject => _detail?.TrustStatus is { ProfileValidated: false, Status: "InReview" } && HasUserCorrectionReason;
    private bool CanSuspend => _detail?.TrustStatus.Status != "Suspended" && !string.IsNullOrWhiteSpace(_reason);
    private bool CanReactivate => _detail?.TrustStatus.Status == "Suspended";

    protected override Task OnInitializedAsync()
    {
        return LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        var result = await VerificationsApi.GetDetailAsync(UserId);
        _isLoading = false;

        if (!result.Succeeded || result.Value is null)
        {
            Snackbar.Add(string.Join(" ", result.Errors), Severity.Error);
            return;
        }

        _detail = result.Value;
        ApplyManualReviewState();
    }

    private async Task SaveManualReviewAsync()
    {
        if (_detail is null)
        {
            return;
        }

        await RunAsync(ManualReviewAction, async () =>
        {
            var request = new AdminManualReviewUpdateRequest(
                _phoneContactStatus,
                _phoneContactStatus == "Responded",
                NullIfWhiteSpace(_phoneContactNotes),
                _evidenceReviewStatus,
                _evidenceReceived,
                NullIfWhiteSpace(_evidenceNotes),
                _declaredDataReviewed,
                _profileCoherent,
                _referencesReviewed,
                _manualInterviewStatus,
                _manualInterviewResult,
                NullIfWhiteSpace(_manualInterviewChannel),
                null,
                _manualInterviewStatus == "Completed" ? DateTimeOffset.UtcNow : null,
                NullIfWhiteSpace(_manualInterviewReference),
                NullIfWhiteSpace(_manualInterviewNotes));

            var result = await VerificationsApi.UpdateManualReviewAsync(UserId, request);
            if (!result.Succeeded || result.Value is null)
            {
                Snackbar.Add(string.Join(" ", result.Errors), Severity.Error);
                return;
            }

            _detail = result.Value;
            ApplyManualReviewState();
            Snackbar.Add("Revision manual guardada.", Severity.Success);
        });
    }

    private async Task ExecuteDecisionAsync(string action)
    {
        if (_detail is null)
        {
            return;
        }

        await RunAsync(action, async () =>
        {
            var request = new AdminReviewDecisionRequest(
                BuildDecisionReason(action),
                string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim());

            var result = action switch
            {
                ApproveAction => await VerificationsApi.ApproveProfileAsync(UserId, request),
                RejectAction => await VerificationsApi.RejectProfileAsync(UserId, request),
                SuspendAction => await VerificationsApi.SuspendAsync(UserId, request),
                ReactivateAction => await VerificationsApi.ReactivateAsync(UserId, request),
                _ => ApiResult<AdminVerificationDetailResponse>.Failure(L["UnknownDecision"].Value)
            };

            if (!result.Succeeded || result.Value is null)
            {
                Snackbar.Add(string.Join(" ", result.Errors), Severity.Error);
                return;
            }

            _detail = result.Value;
            ApplyManualReviewState();
            _reason = string.Empty;
            _notes = string.Empty;
            Snackbar.Add(L["DecisionRegistered"], Severity.Success);
        });
    }

    private async Task RunAsync(string action, Func<Task> work)
    {
        try
        {
            _busyAction = action;
            await work();
        }
        finally
        {
            _busyAction = null;
        }
    }

    private bool IsBusy(string action)
    {
        return string.Equals(_busyAction, action, StringComparison.Ordinal);
    }

    private string? BuildDecisionReason(string action)
    {
        if (action != RejectAction)
        {
            return NullIfWhiteSpace(_reason);
        }

        var manualReason = NullIfWhiteSpace(_reason);
        var correctionMessage = BuildSelectedCorrectionMessage();

        if (string.IsNullOrWhiteSpace(manualReason))
        {
            return NullIfWhiteSpace(correctionMessage);
        }

        if (string.IsNullOrWhiteSpace(correctionMessage))
        {
            return manualReason;
        }

        return $"{manualReason}{Environment.NewLine}{Environment.NewLine}{correctionMessage}";
    }

    private string BuildSelectedCorrectionMessage()
    {
        var selectedItems = CorrectionItems.Where(item => item.Selected).ToArray();
        if (selectedItems.Length == 0)
        {
            return string.Empty;
        }

        return "Correccion requerida: " + string.Join(" ", selectedItems.Select(item => item.UserMessage));
    }

    private void UseCorrectionMessageAsReason()
    {
        var correctionMessage = BuildSelectedCorrectionMessage();
        if (!string.IsNullOrWhiteSpace(correctionMessage))
        {
            _reason = correctionMessage;
        }
    }

    private void ApplyManualReviewState()
    {
        if (_detail?.ManualReview is null)
        {
            return;
        }

        var review = _detail.ManualReview;
        _phoneContactStatus = review.PhoneContactStatus == "Pending" && review.PhoneContacted
            ? "Responded"
            : review.PhoneContactStatus;
        _phoneContactNotes = review.PhoneContactNotes ?? string.Empty;
        _evidenceReceived = review.EvidenceReceivedAt.HasValue;
        _evidenceReviewStatus = review.EvidenceReviewStatus;
        _evidenceNotes = review.EvidenceNotes ?? string.Empty;
        _declaredDataReviewed = review.DeclaredDataReviewed;
        _profileCoherent = review.ProfileCoherent;
        _referencesReviewed = review.ReferencesReviewed;
        _manualInterviewStatus = review.ManualInterviewStatus;
        _manualInterviewResult = review.ManualInterviewResult;
        _manualInterviewChannel = review.ManualInterviewChannel ?? string.Empty;
        _manualInterviewReference = review.ManualInterviewReference ?? string.Empty;
        _manualInterviewNotes = review.ManualInterviewNotes ?? string.Empty;
        SyncCorrectionDefaults();
    }

    private void SyncCorrectionDefaults()
    {
        _phoneCorrection.Selected = _phoneContactStatus is "NoResponse" or "NumberDoesNotExist" or "WrongNumber";
        _identityCorrection.Selected = !_declaredDataReviewed && _detail?.ManualReview?.SubmittedAt is not null;
        _profileCorrection.Selected = !_profileCoherent && _detail?.ManualReview?.SubmittedAt is not null;
        _evidenceCorrection.Selected = _evidenceReviewStatus is "Inconclusive" or "Inconsistent" or "Rejected";
        _interviewCorrection.Selected = _manualInterviewResult is "Inconclusive" or "Failed" or "RequiresFollowUp"
            || _manualInterviewStatus is "NoShow" or "RequiresFollowUp";
    }

    private string GetWhatsAppLink()
    {
        var digits = new string((_detail?.PhoneNumber ?? string.Empty).Where(char.IsDigit).ToArray());
        return string.IsNullOrWhiteSpace(digits) ? "#" : $"https://wa.me/{digits}";
    }

    private static string GetPhoneContactStatusLabel(string status)
    {
        return status switch
        {
            "Responded" => "Si, respondio",
            "NoResponse" => "No respondio",
            "NumberDoesNotExist" => "El numero no existe",
            "WrongNumber" => "Numero equivocado",
            "Busy" => "Ocupado",
            "DifferentPerson" => "Responde otra persona",
            "RescheduleRequested" => "Solicita reprogramar",
            _ => "Pendiente"
        };
    }

    private bool IsPhoneContactCorrectionSuggested()
    {
        return _phoneContactStatus is "NoResponse" or "NumberDoesNotExist" or "WrongNumber" or "DifferentPerson";
    }

    private string GetGuideLocation()
    {
        return FormatLocation(_detail?.GuideProfile?.City, _detail?.GuideProfile?.Country);
    }

    private string GetDeclaredLocation()
    {
        return FormatLocation(_detail?.ManualReview?.City, _detail?.ManualReview?.Country);
    }

    private string GetDeclaredDocument()
    {
        var documentType = _detail?.ManualReview?.DocumentType;
        var last4 = _detail?.ManualReview?.DocumentNumberLast4;
        if (string.IsNullOrWhiteSpace(documentType) && string.IsNullOrWhiteSpace(last4))
        {
            return "-";
        }

        return $"{(string.IsNullOrWhiteSpace(documentType) ? "Documento" : documentType)} **** {(string.IsNullOrWhiteSpace(last4) ? "-" : last4)}";
    }

    private string GetRateAndAvailability()
    {
        if (_detail?.GuideProfile is null)
        {
            return "-";
        }

        var availability = _detail.GuideProfile.AvailableNow ? "Disponible ahora" : "No disponible ahora";
        return $"{_detail.GuideProfile.HourlyRate:0.##} {_detail.GuideProfile.Currency} / {availability}";
    }

    private static string FormatLocation(string? city, string? country)
    {
        if (string.IsNullOrWhiteSpace(city) && string.IsNullOrWhiteSpace(country))
        {
            return "-";
        }

        if (string.IsNullOrWhiteSpace(country))
        {
            return city?.Trim() ?? "-";
        }

        if (string.IsNullOrWhiteSpace(city))
        {
            return country.Trim();
        }

        return $"{city.Trim()}, {country.Trim()}";
    }

    private static string JoinValues(IReadOnlyCollection<string>? values)
    {
        return values is null || values.Count == 0
            ? "-"
            : string.Join(", ", values);
    }

    private static string Summarize(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        var trimmed = value.Trim();
        return trimmed.Length <= 180 ? trimmed : $"{trimmed[..180]}...";
    }

    private static string GetEvidenceReviewStatusLabel(string status)
    {
        return status switch
        {
            "Received" => "Recibida",
            "MatchesDeclaration" => "Coincide con declaracion",
            "Inconclusive" => "No concluyente",
            "Inconsistent" => "Inconsistente",
            "Rejected" => "Rechazada",
            _ => "Pendiente"
        };
    }

    private bool IsEvidenceCorrectionSuggested()
    {
        return _evidenceReviewStatus is "Inconclusive" or "Inconsistent" or "Rejected";
    }

    private Color GetProgressColor()
    {
        if (_detail?.TrustStatus.Status == "Suspended")
        {
            return Color.Error;
        }

        return CompletionPercent >= 100 ? Color.Success : Color.Primary;
    }

    private static string GetInitials(string value)
    {
        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return string.Concat(parts.Take(2).Select(part => part[0])).ToUpperInvariant();
    }

