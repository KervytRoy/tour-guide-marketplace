@page "/login"
@layout AuthLayout
@attribute [AllowAnonymous]
@inject AuthSessionService AuthSession
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResource> L

<MudPaper Class="auth-card" Elevation="0">
    <MudText Typo="Typo.h4">@L["LoginTitle"]</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary">@L["AdminLoginSubtitle"]</MudText>

    @if (_errors.Count > 0)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
            @string.Join(" ", _errors)
        </MudAlert>
    }

    <MudTextField T="string" @bind-Value="_email" Label="@L["Email"]" InputType="InputType.Email"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
    <MudTextField T="string" @bind-Value="_password" Label="@L["Password"]" InputType="InputType.Password"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />

    <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
               Disabled="_isBusy" OnClick="LoginAsync" StartIcon="@Icons.Material.Filled.Login">
        @(_isBusy ? L["LoginLoading"] : L["Login"])
    </MudButton>
</MudPaper>

@code {
    private string _email = string.Empty;
    private string _password = string.Empty;
    private bool _isBusy;
    private IReadOnlyCollection<string> _errors = [];

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.IsInRole(AppRoles.Admin))
        {
            Navigation.NavigateTo(GetReturnUrl());
        }
    }

    private async Task LoginAsync()
    {
        _errors = [];

        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _errors = [L["LoginRequiredError"]];
            return;
        }

        _isBusy = true;
        var result = await AuthSession.LoginAsync(new LoginRequest(_email.Trim(), _password));
        _isBusy = false;

        if (!result.Succeeded || result.Value is null)
        {
            _errors = result.Errors;
            return;
        }

        if (!result.Value.Roles.Contains(AppRoles.Admin, StringComparer.Ordinal))
        {
            await AuthSession.LogoutAsync();
            _errors = [L["AdminRoleRequiredError"]];
            return;
        }

        Snackbar.Add(L["AdminWelcome"], Severity.Success);
        Navigation.NavigateTo(GetReturnUrl());
    }

    private string GetReturnUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl) || ReturnUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
        {
            return "/admin/verifications";
        }

        return $"/{ReturnUrl.TrimStart('/')}";
    }
}
