@page "/not-found"

<MudPaper Class="state-panel" Elevation="0">
    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Secondary" Size="Size.Large" />
    <MudText Typo="Typo.h5">Pagina no encontrada</MudText>
    <MudText Color="Color.Secondary">La ruta que intentaste abrir no existe en la consola administrativa.</MudText>
    <MudButton Href="/admin/verifications" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.VerifiedUser">
        Ir a verificaciones
    </MudButton>
</MudPaper>
